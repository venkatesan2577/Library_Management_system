package project;
import java.awt.*;
import javax.swing.*;

public class LibraryManagement {
	
	    // Database credentials (not used here for simplicity)
	    static final String url = "jdbc:mysql://localhost:3306/library";
	    static final String user = "root";
	    static final String pass = "2577";

	    // Issue tracking
	    static int issuedCount = 0; // max 3 books per user

	    // Stock of each book (max 3 copies)
	    static int javaStock = 3;
	    static int pythonStock = 3;
	    static int dsStock = 3;
	    static int dbmsStock = 3;

	    // ================= LOGIN PAGE =================
	    public static void loginPage() {
	        JFrame f = new JFrame("Library Login");
	        f.setLayout(null);

	        Label title = new Label("Library Management System");
	        title.setBounds(150, 40, 400, 40);
	        title.setFont(new Font("Arial", Font.BOLD, 26));
	        f.add(title);

	        Label u = new Label("Username:");
	        u.setBounds(150, 120, 100, 30);
	        f.add(u);

	        TextField ut = new TextField();
	        ut.setBounds(280, 120, 200, 30);
	        f.add(ut);

	        Label p = new Label("Password:");
	        p.setBounds(150, 170, 100, 30);
	        f.add(p);

	        TextField pt = new TextField();
	        pt.setBounds(280, 170, 200, 30);
	        pt.setEchoChar('*');
	        f.add(pt);

	        Button login = new Button("Login");
	        login.setBounds(200, 230, 100, 30);
	        f.add(login);

	        Button signup = new Button("Sign Up");
	        signup.setBounds(330, 230, 100, 30);
	        f.add(signup);

	        // LOGIN (simplified, does not use database)
	        login.addActionListener(e -> {
	            if (!ut.getText().isEmpty() && !pt.getText().isEmpty()) {
	                JOptionPane.showMessageDialog(f, "Login Successful");
	                f.dispose();
	                menuPage();
	            } else {
	                JOptionPane.showMessageDialog(f, "Invalid Login");
	            }
	        });

	        signup.addActionListener(e -> {
	            JOptionPane.showMessageDialog(f, "Account Created");
